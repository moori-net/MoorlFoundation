{% block moorl_location_card %}
    <mt-card
        class="moorl-location-card"
        :title="$tc('moorl-location-card.name')"
    >
        <template #headerRight>
            <moorl-router-link plugin="MoorlFoundation"/>
        </template>

        <moorl-location v-bind="$attrs"/>
    </mt-card>
{% endblock %}
