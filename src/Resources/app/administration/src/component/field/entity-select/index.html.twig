<div class="moorl-entity-select-field">
    <div class="moorl-entity-select-field__fieldset">
        <sw-entity-single-select
            v-bind="vBind"
            v-model:value="currentValue"
        />
        <div class="sw-field">
            <div
                    v-if="fieldLabel"
                    class="sw-field__label"
            >&nbsp;</div>

            <div class="sw-block-field__block">
                <sw-button-group
                        v-if="showEditButton"
                        :split-button="true"
                >
                    <mt-button
                            variant="primary"
                            size="small"
                            @click="showEditModal = true"
                            :disabled="disabled"
                    >
                        {{ currentValue ? $tc('global.default.edit') : $tc('global.default.add') }}
                    </mt-button>

                    <sw-context-button v-if="currentValue && routerLink">
                        <template #button>
                            <mt-button
                                    square
                                    variant="primary"
                                    :disabled="disabled"
                                    size="small"
                            >
                                <mt-icon
                                        name="regular-chevron-down-xs"
                                        size="16"
                                />
                            </mt-button>
                        </template>

                        <sw-context-menu-item @click="openNewTab">
                            {{ $tc('sw-category.base.link.linkNewTabLabel') }}
                        </sw-context-menu-item>
                    </sw-context-button>
                </sw-button-group>

                <mt-button
                        v-else
                        variant="primary"
                        size="small"
                        @click="openNewTab"
                        :disabled="disabled"
                >
                    {{ currentValue ? $tc('global.default.edit') : $tc('global.default.add') }}
                </mt-button>
            </div>
        </div>
    </div>

    <moorl-modal-detail
        v-if="showEditButton && showEditModal"
        v-model:value="currentValue"
        :entity="entity"
        :defaultItem="defaultItem"
        @close="showEditModal = false"
    />
</div>
